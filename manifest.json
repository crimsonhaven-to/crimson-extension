{
  "manifest_version": 3,
  "name": "Crimson Haven Companion",
  "short_name": "Crimson Companion",
  "version": "1.0.3",
  "description": "Local CORS unblock + header injection for Crimson Haven. Lets the site scrape and play sources straight from your browser — no backend in the path. 🦇",
  "author": "Crimson Haven",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Crimson Haven Companion",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://crimsonhaven.to/*",
        "https://*.crimsonhaven.to/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/inpage.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://crimsonhaven.to/*",
        "https://*.crimsonhaven.to/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/protocol.js", "src/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    }
  ]
}
